// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String  @id @default(cuid())
  externalId  String  @unique
  email       String  @unique
  phoneNumber String?

  role    UserRole @default(USER)
  profile Profile?
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String
  lastName    String
  dateOfBirth String?
  school      String?
  bio         String?
  age         Int?
  isActive    Boolean? @default(false)

  address UserAddress?

  positions Position[]
  batting   Batting?
  throwing  Throwing?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserAddress {
  id        String @id @default(cuid())
  profileId String @unique
  street    String
  city      String
  state     String
  zip       String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  USER
}

enum Batting {
  RIGHT
  LEFT
  SWITCH
}

enum Throwing {
  RIGHT
  LEFT
  SWITCH
}

enum Position {
  PITCHER
  CATCHER
  FIRSTBASE
  SECONDBASE
  THIRDBASE
  SHORTSTOP
  LEFTFIELD
  CENTERFIELD
  RIGHTFIELD
  DESIGNATEDHITTER
  BENCH
}
